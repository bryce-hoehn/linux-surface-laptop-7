2.43.0

NOT FOR UPSTREAM — ov02c10-specific AGC & gamma defaults
Adjust the global default values for gamma and exposure.

Ideally, the AGC target, AGC step size, and default gamma should be
configurable per-sensor via the YAML tuning file rather than hardcoded.

--- a/src/ipa/simple/algorithms/agc.cpp
+++ b/src/ipa/simple/algorithms/agc.cpp
@@ -26,9 +26,9 @@
 
 /*
  * The exposure is optimal when the mean sample value of the histogram is
- * in the middle of the range.
+ * in the middle of the range. Lowered for ov02c10 which overexposes at 2.5.
  */
-static constexpr float kExposureOptimal = kExposureBinsCount / 2.0;
+static constexpr float kExposureOptimal = 1.5;
 
 /*
  * This implements the hysteresis for the exposure adjustment.
@@ -46,8 +46,9 @@
 	/*
 	 * kExpDenominator of 10 gives ~10% increment/decrement;
 	 * kExpDenominator of 5 - about ~20%
+	 * Set to 4 for ~25% step (faster convergence on ov02c10).
 	 */
-	static constexpr uint8_t kExpDenominator = 10;
+	static constexpr uint8_t kExpDenominator = 4;
 	static constexpr uint8_t kExpNumeratorUp = kExpDenominator + 1;
 	static constexpr uint8_t kExpNumeratorDown = kExpDenominator - 1;
 

